{
    "name": "mgamadeus/ddd-common-translations",
    "description": "Texts, entity translations, app translations, embeddings for mgamadeus/ddd",
    "minimum-stability": "stable",
    "license": "MIT",
    "version": "1.0.3",
    "authors": [
        {
            "name": "Marius-Eugen Gerdan",
            "email": "marius@gerdan.net"
        }
    ],
    "require": {
        "mgamadeus/ddd": "^2.10",
        "mgamadeus/ddd-ai": "^1.0",
        "mgamadeus/ddd-common-political": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "DDD\\": "src/"
        }
    },
    "extra": {
        "ddd-module": "DDD\\Modules\\Translations\\TranslationsModule"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
